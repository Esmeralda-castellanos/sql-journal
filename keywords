UNION ALL / UNION DISTINCT
# UNION ALL
Stacks all rows from two or more queries on top of each other.
Every row is included, even if duplicates exist across the queries.
Fastest set operator — no deduplication step.
-- example
SELECT column_1,
       column_2
FROM table_a
UNION ALL
SELECT column_1,
       column_2
FROM table_b;

# UNION DISTINCT
Stacks rows from two or more queries, like UNION ALL.
Removes duplicate rows from the result.
Use when the same row may appear across tables and each unique row should appear only once.
Slower than UNION ALL because of the deduplication step.
SELECT column_1,
       column_2
FROM table_a
UNION DISTINCT
SELECT column_1,
       column_2
FROM table_b;

## Column Compatibility
All SELECT statements in a set operator must return the same number of columns.
Columns must have compatible data types in the same order.
Column names do not need to match — the result uses names from the first SELECT.
Mismatched counts or incompatible types produce an error.

-- Select fields with aliases
SELECT c.code AS country_code, name, year, inflation_rate
FROM countries AS c
-- Join to economies (alias e)
INNER JOIN economies AS e
-- Match on code field using table aliases
ON c.code = e.code;

SELECT c.name AS country, l.name AS language, official
FROM countries AS c
INNER JOIN languages AS l
-- Match using the code column
USING (code);

SELECT c.name AS country, l.name AS language
FROM countries AS c
INNER JOIN languages AS l
USING(code)
WHERE l.name = 'Bhojpuri';

SELECT *
FROM table1
INNER JOIN table2 ON table1.id = table2.id
INNER JOIN table3 ON table2.other_id = table3.id;

--example 
-- Select fields
SELECT name, e.year, fertility_rate, unemployment_rate
FROM countries AS c
INNER JOIN populations AS p
ON c.code = p.country_code
-- Join to economies (as e) match code
INNER JOIN economies AS e ON e.code = c.code;

-- Select local_name and lang_num from appropriate tables
SELECT local_name, lang_num
FROM countries,
  (SELECT code, COUNT(*) AS lang_num
  FROM languages
  GROUP BY code) AS sub
-- Where codes match
WHERE countries.code = sub.code
ORDER BY lang_num DESC;

